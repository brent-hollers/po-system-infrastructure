        "message": "=<div style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;max-width:600px;margin:0 auto;\">\n  <div style=\"background:#1a2e5a;padding:20px 24px;border-radius:8px 8px 0 0;\">\n    <h2 style=\"color:#fff;margin:0;font-size:18px;\">St. Mary's Academy</h2>\n    <p style=\"color:#f5c518;margin:4px 0 0;font-size:13px;\">Purchase Order Approval Request — Principal Review</p>\n  </div>\n  <div style=\"background:#fff;border:1px solid #e5e7eb;border-top:none;padding:24px;border-radius:0 0 8px 8px;\">\n    <p style=\"color:#374151;\">Hi Cynthia,</p>\n    <p style=\"color:#374151;\">The following purchase order has been approved by the Director of Operations and requires your approval.</p>\n    <p style=\"font-size:13px;color:#374151;\"><strong>PO Number:</strong> {{ $('Webhook - Approval Action').first().json.query.po }}<br/><strong>Submitted by:</strong> {{ $('Webhook - Approval Action').first().json.query.email }}</p>\n    <p style=\"color:#6b7280;font-size:13px;\">Please review the details in the <a href=\"https://docs.google.com/spreadsheets/d/1_OkhP9-SlsXrQ5oa_l_AapGQXpDTQn3N6qlX2GJ6fWc\">PO Tracking Sheet</a> and take action below.</p>\n    <div style=\"margin:28px 0 8px;text-align:center;\">\n      <a href=\"https://api.purchases.smaschool.org/webhook/po-approve?po={{ $('Webhook - Approval Action').first().json.query.po }}&stage=principal&action=approve&email={{ $('Webhook - Approval Action').first().json.query.email }}\" style=\"background:#166534;color:#fff;padding:12px 28px;border-radius:6px;text-decoration:none;font-weight:600;font-size:14px;margin-right:12px;\">✓ Approve</a>\n      <a href=\"https://api.purchases.smaschool.org/webhook/po-approve?po={{ $('Webhook - Approval Action').first().json.query.po }}&stage=principal&action=decline&email={{ $('Webhook - Approval Action').first().json.query.email }}\" style=\"background:#991b1b;color:#fff;padding:12px 28px;border-radius:6px;text-decoration:none;font-weight:600