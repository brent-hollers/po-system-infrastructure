    {
      "parameters": {
        "sendTo": "mkomdat@smaschool.org",
        "subject": "=PO Approval Request: {{ $('Prepare PO Data').first().json.poNumber }} — {{ $('Prepare PO Data').first().json.purpose }}",
        "emailType": "html",
        "message": "=<div style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;max-width:600px;margin:0 auto;\">\n  <div style=\"background:#1a2e5a;padding:20px 24px;border-radius:8px 8px 0 0;\">\n    <h2 style=\"color:#fff;margin:0;font-size:18px;\">St. Mary's Academy</h2>\n    <p style=\"color:#f5c518;margin:4px 0 0;font-size:13px;\">Purchase Order Approval Request</p>\n  </div>\n  <div style=\"background:#fff;border:1px solid #e5e7eb;border-top:none;padding:24px;border-radius:0 0 8px 8px;\">\n    <p style=\"color:#374151;\">Hi Mark,</p>\n    <p style=\"color:#374151;\">A new purchase order request requires your approval.</p>\n    <table style=\"width:100%;border-collapse:collapse;margin:16px 0;font-size:13px;\">\n      <tr><td style=\"padding:6px 0;color:#6b7280;width:140px;\">PO Number</td><td style=\"padding:6px 0;font-weight:600;\">{{ $('Prepare PO Data').first().json.poNumber }}</td></tr>\n      <tr><td style=\"padding:6px 0;color:#6b7280;\">Requested By</td><td style=\"padding:6px 0;\">{{ $('Prepare PO Data').first().json.submitterName }} ({{ $('Prepare PO Data').first().json.submitterEmail }})</td></tr>\n      <tr><td style=\"padding:6px 0;color:#6b7280;\">Department</td><td style=\"padding:6px 0;\">{{ $('Prepare PO Data').first().json.department }}</td></tr>\n      <tr><td style=\"padding:6px 0;color:#6b7280;\">Purpose</td><td style=\"padding:6px 0;\">{{ $('Prepare PO Data').first().json.purpose }}</td></tr>\n      <tr><td style=\"padding:6px 0;color:#6b7280;\">Account Code</td><td style=\"padding:6px 0;\">{{ $('Prepare PO Data').first().json.accountCode }}</td></tr>\n      <tr><td style=\"padding:6px 0;color:#6b7280;\">Date Needed</td><td style=\"padding:6px 0;\">{{ $('Prepare PO Data').first().json.dateNeeded }}</td></tr>\n      <tr><td style=\"padding:6px 0;color:#6b7280;\">Total Cost</td><td style=\"padding:6px 0;font-weight:600;color:#1a2e5a;\">{{ $('Prepare PO Data').first().json.totalCostFormatted }}</td></tr>\n      <tr><td style=\"padding:6px 0;color:#6b7280;\">Fulfillment</td><td style=\"padding:6px 0;\">{{ $('Prepare PO Data').first().json.isPersonalFunds ? 'Personal Funds (Reimbursement)' : 'Please Order' }}</td></tr>\n    </table>\n    <h4 style=\"color:#374151;margin:16px 0 8px;\">Items</h4>\n    <table style=\"width:100%;border-collapse:collapse;font-size:12px;\">\n      <tr style=\"background:#f3f4f6;\">\n        <th style=\"padding:6px 8px;border:1px solid #e5e7eb;text-align:left;\">Qty</th>\n        <th style=\"padding:6px 8px;border:1px solid #e5e7eb;text-align:left;\">Item #</th>\n        <th style=\"padding:6px 8px;border:1px solid #e5e7eb;text-align:left;\">Description</th>\n        <th style=\"padding:6px 8px;border:1px solid #e5e7eb;text-align:left;\">Unit Price</th>\n        <th style=\"padding:6px 8px;border:1px solid #e5e7eb;text-align:left;\">Ext. Price</th>\n        <th style=\"padding:6px 8px;border:1px solid #e5e7eb;text-align:left;\">Purchase URL</th>\n      </tr>\n      {{ $('Prepare PO Data').first().json.itemSummaryHtml }}\n    </table>\n    <h4 style=\"color:#374151;margin:16px 0 8px;\">Vendor</h4>\n    <p style=\"font-size:13px;color:#374151;margin:0;\">{{ $('Prepare PO Data').first().json.vendor.name }}<br/>{{ $('Prepare PO Data').first().json.vendor.address }}<br/>{{ $('Prepare PO Data').first().json.vendor.cityStateZip }}<br/>{{ $('Prepare PO Data').first().json.vendor.phone }}</p>\n    <div style=\"margin:28px 0 8px;text-align:center;\">\n      <a href=\"https://api.purchases.smaschool.org/webhook/po-approve?po={{ $('Prepare PO Data').first().json.poNumber }}&stage=doo&action=approve&email={{ $('Prepare PO Data').first().json.submitterEmail }}\" style=\"background:#166534;color:#fff;padding:12px 28px;border-radius:6px;text-decoration:none;font-weight:600;font-size:14px;margin-right:12px;\">✓ Approve</a>\n      <a href=\"https://api.purchases.smaschool.org/webhook/po-approve?po={{ $('Prepare PO Data').first().json.poNumber }}&stage=doo&action=decline&email={{ $('Prepare PO Data').first().json.submitterEmail }}\" style=\"background:#991b1b;color:#fff;padding:12px 28px;border-radius:6px;text-decoration:none;font-weight:600;font-size:14px;\">✗ Decline</a>\n    </div>\n    <p style=\"font-size:11px;color:#9ca3af;text-align:center;margin-top:16px;\">St. Mary's Academy Purchase Order System</p>\n  </div>\n</div>",
        "options": {
          "replyTo": "noreply@smaschool.org"
        }
      },
