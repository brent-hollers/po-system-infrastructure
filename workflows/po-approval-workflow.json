{
  "name": "PO Approval Workflow",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "po-submit",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "1",
      "name": "Webhook - PO Submit",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [240, 300]
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body ?? $input.first().json;\n\n// Generate PO number: PO-YYYYMMDD-XXXX\nconst now = new Date();\nconst pad = (n) => String(n).padStart(2,'0');\nconst datePart = `${now.getFullYear()}${pad(now.getMonth()+1)}${pad(now.getDate())}`;\nconst randPart = String(Math.floor(Math.random()*9000)+1000);\nconst poNumber = `PO-${datePart}-${randPart}`;\n\n// Build item links summary (for emails and Sheets)\nconst lineItems = (body.lineItems || []).filter(i => i.description);\nconst itemSummaryHtml = lineItems.map((item, idx) => {\n  const url = item.purchaseUrl ? `<a href=\"${item.purchaseUrl}\">${item.purchaseUrl}</a>` : '—';\n  return `<tr>\n    <td style=\"padding:4px 8px;border:1px solid #e5e7eb;\">${item.quantity}</td>\n    <td style=\"padding:4px 8px;border:1px solid #e5e7eb;\">${item.itemNumber || '—'}</td>\n    <td style=\"padding:4px 8px;border:1px solid #e5e7eb;\">${item.description}</td>\n    <td style=\"padding:4px 8px;border:1px solid #e5e7eb;\">$${Number(item.unitPrice||0).toFixed(2)}</td>\n    <td style=\"padding:4px 8px;border:1px solid #e5e7eb;\">$${Number(item.extPrice||0).toFixed(2)}</td>\n    <td style=\"padding:4px 8px;border:1px solid #e5e7eb;\">${url}</td>\n  </tr>`;\n}).join('');\n\nconst itemLinksPlain = lineItems\n  .filter(i => i.purchaseUrl)\n  .map(i => `${i.description}: ${i.purchaseUrl}`)\n  .join('\\n');\n\nconst submittedAt = now.toISOString();\n\nreturn [{\n  json: {\n    ...body,\n    poNumber,\n    submittedAt,\n    lineItems,\n    itemSummaryHtml,\n    itemLinksPlain,\n    totalCostFormatted: `$${Number(body.totalCost||0).toFixed(2)}`,\n    isPersonalFunds: body.personalFunds === true || body.personalFunds === 'true',\n  }\n}];"
      },
      "id": "2",
      "name": "Prepare PO Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "operation": "append",
        "documentId": {
          "__rl": true,
          "value": "1_OkhP9-SlsXrQ5oa_l_AapGQXpDTQn3N6qlX2GJ6fWc",
          "mode": "id"
        },
        "sheetName": {
          "__rl": true,
          "value": "All Requests",
          "mode": "name"
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "PO #": "={{ $json.poNumber }}",
            "Submitter Name": "={{ $json.submitterName }}",
            "Submitter Email": "={{ $json.submitterEmail }}",
            "Department": "={{ $json.department }}",
            "Date Requested": "={{ $json.dateRequested }}",
            "Date Needed": "={{ $json.dateNeeded }}",
            "Purpose": "={{ $json.purpose }}",
            "Account Code": "={{ $json.accountCode }}",
            "Personal Funds": "={{ $json.isPersonalFunds ? 'Yes' : 'No' }}",
            "Total Cost": "={{ $json.totalCostFormatted }}",
            "Vendor Name": "={{ $json.vendor.name }}",
            "Status": "=Pending - Director of Operations",
            "Submitted At": "={{ $json.submittedAt }}"
          }
        },
        "options": {}
      },
